# NextGen Economy Frontend Configuration
#
# Copy to .env and fill in after deploying contracts:
#   cp .env.example .env
#
# Contract addresses (from Hardhat deploy scripts)
REACT_APP_TOKEN_ADDRESS=0x...
REACT_APP_IOT_ADDRESS=0x...
REACT_APP_SENTINEL_ADDRESS=0x...

# API endpoints (from CloudFormation stack outputs)
REACT_APP_TOKEN_API=https://xxx.execute-api.us-east-1.amazonaws.com/dev
REACT_APP_SENTINEL_API=https://xxx.execute-api.us-east-1.amazonaws.com/Prod

# Network
REACT_APP_CHAIN_ID=11155111
REACT_APP_CHAIN_NAME=Sepolia
REACT_APP_EXPLORER_URL=https://sepolia.etherscan.io

# Cognito auth (from nge-auth CloudFormation stack outputs)
REACT_APP_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
REACT_APP_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
REACT_APP_COGNITO_REGION=us-east-1
