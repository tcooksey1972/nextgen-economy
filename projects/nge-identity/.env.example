# NextGen Economy — NGE Identity Platform
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ─── Testnet Deployment ─────────────────────────────────
# Required for deploying contracts to Base Sepolia or Sepolia

# Your deployer wallet private key (with testnet ETH)
# Get Base Sepolia ETH from: https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# RPC endpoints (pick one or both)
ETH_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Deployment Steps ───────────────────────────────────
#
# 1. Fund your deployer wallet with testnet ETH:
#    - Base Sepolia: https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
#    - Sepolia: https://sepoliafaucet.com/
#
# 2. Set your private key and RPC URL above
#
# 3. Compile contracts:
#    npx hardhat compile
#
# 4. Deploy all contracts:
#    npx hardhat run scripts/deploy.js --network baseSepolia
#
# 5. Copy the deployed addresses into your SAM template params:
#    sam deploy --guided --template-file template.yaml
#
# 6. Verify contracts on block explorer:
#    npx hardhat verify --network baseSepolia <CONTRACT_ADDRESS>

# ─── AWS Serverless Backend ─────────────────────────────
# These are used by the SAM template (template.yaml).
# After deploying contracts, fill in the addresses below
# and pass them as SAM parameters.

# DID_REGISTRY_ADDRESS=0x...
# CREDENTIAL_REGISTRY_ADDRESS=0x...
# MARKETPLACE_ADDRESS=0x...
# SENSOR_ANCHOR_ADDRESS=0x...
# SIGNER_PRIVATE_KEY=0x...  (same as DEPLOYER or separate operations key)
# ALERT_EMAIL=you@example.com
# FHIR_SERVER_URL=https://hapi.fhir.org/baseR4  (optional — HAPI test server)
