# NextGen Economy — Sentinel Monitor (AWS Serverless)
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# These values are passed to SAM deploy via --parameter-overrides
# or can be used by local development scripts.

# Required: Ethereum JSON-RPC endpoint
ETH_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Required: Deployed FullSentinelVault contract address
CONTRACT_ADDRESS=0x_deployed_contract_address_here

# Required: Email for SNS alert notifications
ALERT_EMAIL=you@example.com

# Optional: override defaults
# CHAIN_ID=11155111
# POLL_BLOCK_RANGE=100
# HEARTBEAT_WARNING_HOURS=48
