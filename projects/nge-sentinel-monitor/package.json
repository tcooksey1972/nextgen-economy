{
  "name": "nge-sentinel-monitor",
  "version": "1.0.0",
  "description": "AWS serverless monitoring backend for NGE Sentinel smart contracts — polls on-chain events, stores in DynamoDB, sends alerts via SNS, serves a dashboard via API Gateway + S3.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "test": "node tests/run.js",
    "deploy": "sam build && sam deploy --guided",
    "deploy:stack": "sam build && sam deploy --no-confirm-changeset",
    "local:api": "sam local start-api",
    "local:invoke": "sam local invoke"
  },
  "keywords": [
    "ethereum",
    "solidity",
    "aws",
    "serverless",
    "lambda",
    "monitoring",
    "smart-contracts",
    "security"
  ],
  "author": "Cloud Creations LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tcooksey1972/nextgen-economy.git",
    "directory": "projects/nge-sentinel-monitor"
  },
  "dependencies": {
    "ethers": "^6.16.0"
  }
}
